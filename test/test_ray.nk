Root {
 inputs 0
 name /home/latuser/git/DeepC/test/test_ray.nk
 project_directory "\[python \{nuke.script_directory()\}]"
 last_frame 1
 format "128 72 0 0 128 72 1 128x72"
 proxy_type scale
 proxy_format "1024 778 0 0 1024 778 1 1K_Super_35(full-ap)"
 colorManagement Nuke
 workingSpaceLUT linear
 monitorLut sRGB
 monitorOutLUT rec709
 int8Lut sRGB
 int16Lut sRGB
 logLut Cineon
 floatLut linear
}
Reformat {
 inputs 0
 type "to box"
 box_width 128
 box_height 72
 box_fixed true
 name Reformat1
 xpos 203
 ypos -523
}
Grid {
