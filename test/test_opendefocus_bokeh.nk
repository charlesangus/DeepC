# Nuke script — DeepCOpenDefocus bokeh disc integration test
# Single bright deep pixel exercises bokeh disc spread shape at
# a controlled defocus distance (focus at depth 10, sample at depth 1).
# Run with: nuke -x test/test_opendefocus_bokeh.nk

Root {
 inputs 0
 name test_opendefocus_bokeh
 first_frame 1
 last_frame 1
 fps 24
 format "128 72 0 0 128 72 1 DeepTest128x72"
}

DeepCConstant {
 inputs 0
 name DeepCConstant1
 xpos 0
 ypos 0
 format "128 72 0 0 128 72 1 DeepTest128x72"
 color_front {1 1 1 1}
 front 1.0
 back 1.5
}

DeepCOpenDefocus {
 inputs 1
 name DeepCOpenDefocus1
 xpos 0
 ypos 100
 focal_length 50
 fstop 2.8
 focus_distance 10
 sensor_size_mm 36
}

Write {
 inputs 1
 name Write1
 xpos 0
 ypos 200
 file test/output/bokeh.exr
 file_type exr
 first 1
 last 1
}
