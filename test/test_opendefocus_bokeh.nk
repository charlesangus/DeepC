# Nuke script — DeepCOpenDefocus bokeh disc integration test (R066)
# Single bright pixel converted to deep via DeepFromImage; exercises
# bokeh disc spread shape at a controlled defocus distance.
# Run with: nuke -x test/test_opendefocus_bokeh.nk

Root {
 inputs 0
 name test_opendefocus_bokeh
 first_frame 1
 last_frame 1
 fps 24
 format "256 256 0 0 256 256 1 DeepTest256x256"
}

Constant {
 inputs 0
 name Constant1
 xpos 0
 ypos 0
 color {1 1 1 1}
 format "256 256 0 0 256 256 1 DeepTest256x256"
}

Crop {
 inputs 1
 name Crop1
 xpos 0
 ypos 100
 box {127 127 128 128}
}

DeepFromImage {
 inputs 1
 name DeepFromImage1
 xpos 0
 ypos 200
 set_z true
 z 1.0
}

DeepCOpenDefocus {
 inputs 1
 name DeepCOpenDefocus1
 xpos 0
 ypos 300
 focal_length 50
 fstop 2.8
 focus_distance 10
 sensor_size_mm 36
}

Write {
 inputs 1
 name Write1
 xpos 0
 ypos 400
 file test/output/bokeh.exr
 file_type exr
 first_frame 1
 last_frame 1
}
