# Nuke script — DeepCOpenDefocus camera link integration test (R062)
# Camera2 drives focal/fstop/focus_distance; null holdout via push 0.
# Run with: nuke -x test/test_opendefocus_camera.nk

Root {
 inputs 0
 name test_opendefocus_camera
 first_frame 1
 last_frame 1
 fps 24
 format "128 72 0 0 128 72 1 DeepTest128x72"
}

Camera2 {
 inputs 0
 name Camera1
 xpos 0
 ypos 0
 focal 35
 haperture 2.4
 fstop 1.4
 focal_point 200
}

push 0

DeepConstant {
 inputs 0
 name DeepConstant1
 xpos 150
 ypos 0
 format "128 72 0 0 128 72 1 DeepTest128x72"
 color {0.5 0.5 0.5 1.0}
 deep_front 5.0
 deep_back 5.5
}

DeepCOpenDefocus {
 inputs 3
 name DeepCOpenDefocus1
 xpos 75
 ypos 100
 focal_length 50
 fstop 2.8
 focus_distance 5.0
 sensor_size_mm 36
}

Write {
 inputs 1
 name Write1
 xpos 75
 ypos 200
 file test/output/camera.exr
 file_type exr
 first_frame 1
 last_frame 1
}
