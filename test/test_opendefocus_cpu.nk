# Nuke script — DeepCOpenDefocus CPU-only integration test (R063)
# Forces CPU renderer via use_gpu 0 knob.
# Run with: nuke -x test/test_opendefocus_cpu.nk

Root {
 inputs 0
 name test_opendefocus_cpu
 first_frame 1
 last_frame 1
 fps 24
 format "128 72 0 0 128 72 1 DeepTest128x72"
}

DeepCConstant {
 inputs 0
 name DeepCConstant1
 xpos 0
 ypos 0
 format "128 72 0 0 128 72 1 DeepTest128x72"
 color_front {0.5 0.5 0.5 1.0}
 front 5.0
 back 5.5
}

DeepCOpenDefocus {
 inputs 1
 name DeepCOpenDefocus1
 xpos 0
 ypos 100
 focal_length 50
 fstop 2.8
 focus_distance 5.0
 sensor_size_mm 36
 use_gpu 0
}

Write {
 inputs 1
 name Write1
 xpos 0
 ypos 200
 file test/output/cpu.exr
 file_type exr
 first 1
 last 1
}
