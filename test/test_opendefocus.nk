# Nuke script — DeepCOpenDefocus integration test
# Produces a 128x72 defocused EXR from a synthetic deep constant image.
# Run with: nuke -x test/test_opendefocus.nk

Root {
 inputs 0
 name test_opendefocus
 first_frame 1
 last_frame 1
 fps 24
 format "128 72 0 0 128 72 1 DeepTest128x72"
}

DeepConstant {
 inputs 0
 name DeepConstant1
 xpos 0
 ypos 0
 format "128 72 0 0 128 72 1 DeepTest128x72"
 color {0.5 0.5 0.5 1.0}
 deep_front 5.0
 deep_back 5.5
}

DeepCOpenDefocus {
 inputs 1
 name DeepCOpenDefocus1
 xpos 0
 ypos 100
 focal_length 50
 fstop 2.8
 focus_distance 5.0
 sensor_size_mm 36
}

Write {
 inputs 1
 name Write1
 xpos 0
 ypos 200
 file /tmp/test_opendefocus.exr
 file_type exr
 first_frame 1
 last_frame 1
}
